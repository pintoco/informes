# ── Variables para docker-compose.yml ─────────────────────
# Copia este archivo como .env y edita los valores reales

# Base de datos (sólo si cambias los defaults)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=elemental_pro

# AWS — para desarrollo local puedes usar credenciales reales de AWS
# o apuntar a LocalStack (ver docker-compose.localstack.yml)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# S3 buckets (deben existir en tu cuenta AWS o en LocalStack)
S3_BUCKET_PHOTOS=elemental-pro-photos-dev
S3_BUCKET_PDFS=elemental-pro-pdfs-dev

# SQS (para generación de PDFs)
SQS_PDF_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/elemental-pro-pdf-jobs

# Cognito (para autenticación)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=elemental-pro.auth.us-east-1.amazoncognito.com
