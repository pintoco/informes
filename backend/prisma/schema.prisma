generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  TECHNICIAN
  ADMIN
  SUPER_ADMIN // reservado para uso futuro — no expuesto en ningún endpoint
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSTALLATION
  OTHER
}

enum PhotoCategory {
  BEFORE
  AFTER
}

enum PdfStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  cognitoSub   String?    @unique
  email        String     @unique
  name         String
  phone        String?
  passwordHash String?
  role         Role       @default(TECHNICIAN)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  services     Service[]
}

// ─── Companies ────────────────────────────────────────────────────────────────

model Company {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]
}

model Location {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([companyId, name])
  @@index([companyId])
}

// ─── Services (Órdenes de Trabajo) ────────────────────────────────────────────

model Service {
  id                  String          @id @default(uuid())
  // Número de orden único por año (YYYY-NNN). Generado con advisory lock.
  ordenTrabajo        String          @unique
  razonSocial         String
  ubicacion           String
  contactoTerreno     String
  fecha               DateTime
  horaInicio          String
  responsable         String
  nombreTecnico       String
  fono                String
  email               String
  tipoMantenimiento   MaintenanceType
  comentarioNvr       String?
  comentarioCamaras   String?
  observaciones       String?
  firmaUrl            String?
  firmaNombreReceptor String?

  // Auditoría
  createdBy String?
  updatedBy String?
  deletedBy String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User?          @relation(fields: [createdBy], references: [id])
  photos ServicePhoto[]
  pdfs   ServicePdf[]

  @@index([ubicacion])
  @@index([fecha])
  @@index([deletedAt])
  @@index([createdBy])
}

// ─── Photos ───────────────────────────────────────────────────────────────────

model ServicePhoto {
  id           String        @id @default(uuid())
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id])
  categoria    PhotoCategory
  s3Key        String
  url          String
  originalName String
  sizeBytes    Int
  orden        Int           @default(0)
  createdAt    DateTime      @default(now())

  @@index([serviceId])
}

// ─── PDFs ─────────────────────────────────────────────────────────────────────

model ServicePdf {
  id           String    @id @default(uuid())
  serviceId    String
  service      Service   @relation(fields: [serviceId], references: [id])
  version      Int
  status       PdfStatus @default(PENDING)
  s3Key        String?
  url          String?
  errorMessage String?

  // Auditoría y snapshot
  requestedBy  String?  // userId que solicitó la generación
  generatedBy  String?  // siempre el worker ("pdf-worker")
  dataSnapshot Json?    // snapshot del servicio al momento de generar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
}
