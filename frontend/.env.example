# Modo de auth: "local" (sin AWS) o "cognito" (con AWS Cognito)
VITE_AUTH_MODE=local

# URL de la API (en Docker usa /api por el proxy de Vite)
VITE_API_URL=/api

# Solo necesario cuando VITE_AUTH_MODE=cognito:
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=elemental-pro.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=https://xxxxxxxxxx.cloudfront.net
